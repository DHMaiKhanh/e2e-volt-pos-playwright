# =====================================================
# Sample env file — copy to .env.local / .env.stage / .env.prod
# DO NOT commit real credentials. Real env files are in .gitignore.
# =====================================================

# Runtime
ENV=local
HEADLESS=true
SLOW_MO=0

# Volt POS app
BASE_URL=http://localhost:1420
GRAPHQL_URL=http://localhost:1420/graphql
API_TIMEOUT=30000

# Owner/tenant passcode used to authorize payment completion in the passcode dialog
OWNER_PASSCODE=8888

# Logging
LOG_LEVEL=info

# Portal (dev.v2.fastboypay.com) — used only by tests/portal/**.
# Auth is SSO (GCI Business / Google), so it can't be scripted end-to-end:
# run `npm run auth` once, log in by hand in the browser that opens, then the
# session is cached at PORTAL_STORAGE_STATE for subsequent runs.
PORTAL_BASE_URL=https://dev.v2.fastboypay.com
PORTAL_STORAGE_STATE=.auth/portal-storage-state.json
